# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Allowed Telegram User IDs (comma separated)
# @userinfobot 에게 메시지 보내면 본인 ID 확인 가능
ALLOWED_USER_IDS=123456789

# NAS 주소 (내부 IP 또는 도메인)
NAS_HOST=192.168.0.100

# GitHub 연동 (선택). 비어 있으면 비활성화.
# - TOKEN: Personal Access Token (classic) with 'repo' scope
# - OWNER: 비면 토큰 소유자의 user repo 로 생성, 값이 있으면 organization repo
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_PRIVATE=true
GIT_USER_NAME=NAS Agent
GIT_USER_EMAIL=nas-agent@local
